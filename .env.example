NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAIL=

# Envelope encryption keys (base64-encoded 32-byte KEK values by key id)
SECURITY_KEKS_JSON={"kek_v1":"<base64-32-byte-key>"}
SECURITY_ACTIVE_KEK_ID=kek_v1

# HMAC key for deterministic lookup tags (base64-encoded >= 32 bytes)
SECURITY_HMAC_KEY=<base64-32-byte-key>

# Attendee token signing keys (Ed25519 PEM keypair by kid)
ATTENDEE_TOKEN_KEYS_JSON=[{"kid":"atk_v1","privateKeyPem":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","publicKeyPem":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"}]
ATTENDEE_TOKEN_ACTIVE_KID=atk_v1

# Optional token settings
ATTENDEE_TOKEN_ISSUER=avtive
ATTENDEE_TOKEN_AUDIENCE=attendee-card
ATTENDEE_TOKEN_TTL_SECONDS=600

# Optional password pepper (base64 random 32 bytes)
PASSWORD_PEPPER=<base64-32-byte-random>
